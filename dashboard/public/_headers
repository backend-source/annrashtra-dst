# Cloudflare static-assets honors this file. The HTML shell must never be cached,
# or browsers keep serving an old bundle after a deploy (this caused the 405 login
# and "Not found" cash bugs). Hashed JS/CSS under /assets/* are safe to cache hard.
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/assets/*
  Cache-Control: public, max-age=31536000, immutable
