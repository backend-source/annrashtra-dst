# Copy to .env (gitignored) and fill in. Never commit real values.

# Server
PORT=8080
NODE_ENV=development
# Comma-separated allowed browser origins for CORS (the dashboard URL in prod).
# Leave empty in development to allow all origins.
CORS_ORIGIN=

# Neon Postgres (Mumbai ap-south-1 if available, else Singapore)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d
OTP_TTL_SECONDS=300
# Temporary: set to true to bypass OTP (direct login by mobile) until MSG91/DLT is live.
# Leave false/unset in real production once OTP works. INSECURE while true.
OTP_DISABLED=false

# MSG91 (SMS + WhatsApp). DLT-registered sender + templates required.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=
MSG91_WHATSAPP_NUMBER=
# Optional: if set, the delivery webhook requires header  x-webhook-secret: <this>
MSG91_WEBHOOK_SECRET=

# Firebase Storage (asia-south1) — app uploads, API stores URLs only
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Razorpay (optional online UPI)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
